APP_NAME=URL Health Monitor
APP_VERSION=1.0.0
DEBUG=false

DATABASE_URL=sqlite:///./health_monitor.db
ASYNC_DATABASE_URL=sqlite+aiosqlite:///./health_monitor.db

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

DEFAULT_CHECK_INTERVAL=60
REQUEST_TIMEOUT=30
MAX_RETRIES=3

SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFICATION_EMAILS=

INCIDENT_THRESHOLD=3
RESPONSE_TIME_WARNING_MS=2000
